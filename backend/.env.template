# ============================================================================
# FLEET ACCIDENT REPORTER — DEVELOPMENT .env (copy to .env)
# ============================================================================
# Defaults: Supabase DB · Auth0 auth · AWS cloud · OpenAI for AI
# Change *_PROVIDER values and uncomment the matching block to switch.
# Full docs: docs/ONBOARDING.md
# ============================================================================

# ── 1. CORE ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=Fleet Accident Reporter
APP_VERSION=1.0.0

# ── 2. DATABASE (supabase | neon | postgresql | snowflake | prisma_accelerate)
DB_PROVIDER=supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
DB_HOST=
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=
DB_SSL=true
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=10000
DB_CONNECTION_TIMEOUT=2000

# ── 3. AUTH (auth0 | jwt)
AUTH_PROVIDER=auth0
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=
AUTH0_CALLBACK_URL=http://localhost:3000/api/auth/callback
AUTH0_LOGOUT_URL=http://localhost:3001
JWT_SECRET=
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET=
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900000

# ── 4. CLOUD (aws | azure | gcp)
CLOUD_PROVIDER=aws
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# ── 5. AI (openai | anthropic | aws_rekognition | azure_vision | google_vision | ollama | mistral | openrouter)
AI_PROVIDER=openai
AI_MIN_CONFIDENCE=70
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── 6. NETWORK
CORS_ORIGIN=http://localhost:3001,http://localhost:5000,http://localhost:19006
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── 7. LOGGING
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14d

# ── 8. FILE UPLOAD
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# ── 9. WEBSOCKET
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000

# ── 10. TELEMATICS
ENCRYPTION_KEY=
KILL_SWITCH_AUTO_ENGAGE=true
KILL_SWITCH_TIMEOUT_HOURS=24

# ── 11. EMAIL
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# ── 12. MONITORING
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=

# ── 13. FEATURE FLAGS
ENABLE_SWAGGER_DOCS=true
ENABLE_DEBUG_LOGGING=false
ENABLE_METRICS=true
FEATURE_AI_ASSISTANT=true
FEATURE_PHOTO_ANALYSIS=true
FEATURE_AGENTMD_REVIEW=false
FEATURE_ANALYTICS=true
FEATURE_ADVANCED_EXPORTS=true
FEATURE_REALTIME_NOTIFICATIONS=true
FEATURE_OFFLINE_MODE=true
FEATURE_CUSTOM_FORMS=true
FEATURE_VOICE_INPUT=false
FEATURE_RED_TEAM=false
