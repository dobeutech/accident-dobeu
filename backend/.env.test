# Test Environment Configuration
NODE_ENV=test
PORT=3001

# Providers
DB_PROVIDER=postgresql
AUTH_PROVIDER=jwt
CLOUD_PROVIDER=aws
AI_PROVIDER=openai

# Test Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=accident_app_test
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Test Secrets
JWT_SECRET=test-jwt-secret-key-minimum-32-characters-long
SESSION_SECRET=test-session-secret-key-minimum-32-characters-long
ENCRYPTION_KEY=test-encryption-key-minimum-32-characters

# Disable external services in tests
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_S3_BUCKET=test-bucket

# AI (mocked in tests)
OPENAI_API_KEY=test-openai-key
AI_MIN_CONFIDENCE=70

# Test Configuration
LOG_LEVEL=error
CORS_ORIGIN=http://localhost:3000
COOKIE_SECURE=false
