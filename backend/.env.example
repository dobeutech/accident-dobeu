# ============================================================================
# FLEET ACCIDENT REPORTING SYSTEM — ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your values.
# Run `npm run env:setup` (or follow docs/ONBOARDING.md) for guided setup.
#
# PROVIDER QUICK-SELECT (uncomment ONE per category):
#   Database .... DB_PROVIDER=supabase | neon | postgresql | snowflake | prisma_accelerate
#   Cloud ....... CLOUD_PROVIDER=aws | azure | gcp
#   Auth ........ AUTH_PROVIDER=auth0 | (built-in jwt)
#   AI .......... AI_PROVIDER=openai | anthropic | aws_rekognition | azure_vision | google_vision | ollama | mistral | openrouter
# ============================================================================

# ────────────────────────────────────────────────────────────────────────────
# 1. CORE SERVER
# ────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=Fleet Accident Reporter
APP_VERSION=1.0.0

# ────────────────────────────────────────────────────────────────────────────
# 2. DATABASE — Choose ONE provider
# ────────────────────────────────────────────────────────────────────────────
# Provider: supabase | neon | postgresql | snowflake | prisma_accelerate
DB_PROVIDER=supabase

# --- Supabase (default) ---------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# Supabase exposes a Postgres connection string — use these for Sequelize:
DB_HOST=db.your-project.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_supabase_db_password
DB_SSL=true

# --- Neon (serverless Postgres) --------------------------------------------
# DB_PROVIDER=neon
# NEON_CONNECTION_STRING=postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# DB_HOST=ep-xxxx.us-east-2.aws.neon.tech
# DB_PORT=5432
# DB_NAME=neondb
# DB_USER=your_neon_user
# DB_PASSWORD=your_neon_password
# DB_SSL=true

# --- Standard PostgreSQL (self-hosted / RDS / Cloud SQL / Azure PG) --------
# DB_PROVIDER=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=accident_app
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_SSL=false

# --- Snowflake -------------------------------------------------------------
# DB_PROVIDER=snowflake
# SNOWFLAKE_ACCOUNT=your_account.snowflakecomputing.com
# SNOWFLAKE_USERNAME=your_user
# SNOWFLAKE_PASSWORD=your_password
# SNOWFLAKE_DATABASE=ACCIDENT_DB
# SNOWFLAKE_SCHEMA=PUBLIC
# SNOWFLAKE_WAREHOUSE=COMPUTE_WH
# SNOWFLAKE_ROLE=SYSADMIN

# --- Prisma Accelerate (connection pooling) --------------------------------
# DB_PROVIDER=prisma_accelerate
# DATABASE_URL=prisma://accelerate.prisma-data.net/?api_key=your_api_key
# DIRECT_DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# Connection pool (applies to all SQL-based providers)
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=10000
DB_CONNECTION_TIMEOUT=2000

# ────────────────────────────────────────────────────────────────────────────
# 3. AUTHENTICATION — Choose ONE provider
# ────────────────────────────────────────────────────────────────────────────
# Provider: auth0 | jwt (built-in)
AUTH_PROVIDER=auth0

# --- Auth0 -----------------------------------------------------------------
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
AUTH0_AUDIENCE=https://api.yourdomain.com
AUTH0_CALLBACK_URL=http://localhost:3000/api/auth/callback
AUTH0_LOGOUT_URL=http://localhost:3001
AUTH0_MANAGEMENT_API_TOKEN=your_management_api_token

# --- Built-in JWT (fallback / standalone) ----------------------------------
JWT_SECRET=change_me_to_a_random_string_at_least_32_characters
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Session
SESSION_SECRET=change_me_to_another_random_string_at_least_32_chars
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Security
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900000

# ────────────────────────────────────────────────────────────────────────────
# 4. CLOUD PROVIDER — Choose ONE for storage / compute / vision
# ────────────────────────────────────────────────────────────────────────────
# Provider: aws | azure | gcp
CLOUD_PROVIDER=aws

# --- AWS -------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your-s3-bucket-name
# AWS_SESSION_TOKEN=              # only if using temp creds / STS
# AWS_PROFILE=default             # only if using AWS CLI profiles

# --- Azure -----------------------------------------------------------------
# CLOUD_PROVIDER=azure
# AZURE_TENANT_ID=your_azure_tenant_id
# AZURE_CLIENT_ID=your_azure_client_id
# AZURE_CLIENT_SECRET=your_azure_client_secret
# AZURE_SUBSCRIPTION_ID=your_subscription_id
# AZURE_STORAGE_ACCOUNT=your_storage_account
# AZURE_STORAGE_KEY=your_storage_key
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_BLOB_CONTAINER=accident-photos

# --- GCP ------------------------------------------------------------------
# CLOUD_PROVIDER=gcp
# GCP_PROJECT_ID=your_gcp_project_id
# GCP_CLIENT_EMAIL=your_service_account@project.iam.gserviceaccount.com
# GCP_PRIVATE_KEY=your_private_key
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GCP_STORAGE_BUCKET=your-gcs-bucket-name
# GCP_REGION=us-central1

# ────────────────────────────────────────────────────────────────────────────
# 5. AI / ML PROVIDERS — Enable one or more
# ────────────────────────────────────────────────────────────────────────────
# Primary AI provider for image analysis:
# aws_rekognition | azure_vision | google_vision | openai | anthropic | ollama | mistral | openrouter
AI_PROVIDER=openai
AI_MIN_CONFIDENCE=70

# --- OpenAI ----------------------------------------------------------------
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_ORG_ID=org-your_org_id
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Anthropic -------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_VISION_MODEL=claude-sonnet-4-20250514

# --- Ollama (local / self-hosted) ------------------------------------------
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3
# OLLAMA_VISION_MODEL=llava

# --- Mistral ---------------------------------------------------------------
# MISTRAL_API_KEY=your_mistral_api_key
# MISTRAL_MODEL=mistral-large-latest

# --- OpenRouter (multi-model gateway) -------------------------------------
# OPENROUTER_API_KEY=sk-or-your_openrouter_api_key
# OPENROUTER_MODEL=anthropic/claude-sonnet-4-20250514
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_SITE_URL=http://localhost:3000
# OPENROUTER_APP_NAME=Fleet Accident Reporter

# --- AWS Rekognition (image-only) ------------------------------------------
# (uses AWS creds from Cloud Provider section)
# AI_PROVIDER=aws_rekognition

# --- Azure Computer Vision -------------------------------------------------
# AI_PROVIDER=azure_vision
# AZURE_VISION_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# AZURE_VISION_KEY=your_azure_vision_key

# --- Google Cloud Vision ---------------------------------------------------
# AI_PROVIDER=google_vision
# (uses GCP creds from Cloud Provider section)

# ────────────────────────────────────────────────────────────────────────────
# 6. CORS
# ────────────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3001,http://localhost:5000,http://localhost:19006

# ────────────────────────────────────────────────────────────────────────────
# 7. RATE LIMITING
# ────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ────────────────────────────────────────────────────────────────────────────
# 8. LOGGING
# ────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14d

# ────────────────────────────────────────────────────────────────────────────
# 9. FILE UPLOADS
# ────────────────────────────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# ────────────────────────────────────────────────────────────────────────────
# 10. WEBSOCKET / REAL-TIME
# ────────────────────────────────────────────────────────────────────────────
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000

# ────────────────────────────────────────────────────────────────────────────
# 11. TELEMATICS & KILL SWITCH
# ────────────────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=change_me_to_a_random_32_char_encryption_key
KILL_SWITCH_AUTO_ENGAGE=true
KILL_SWITCH_TIMEOUT_HOURS=24

# ────────────────────────────────────────────────────────────────────────────
# 12. EMAIL (SMTP)
# ────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@yourdomain.com

# ────────────────────────────────────────────────────────────────────────────
# 13. MONITORING & OBSERVABILITY
# ────────────────────────────────────────────────────────────────────────────
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=

# ────────────────────────────────────────────────────────────────────────────
# 14. FEATURE FLAGS
# ────────────────────────────────────────────────────────────────────────────
ENABLE_SWAGGER_DOCS=true
ENABLE_DEBUG_LOGGING=false
ENABLE_METRICS=true
FEATURE_AI_ASSISTANT=true
FEATURE_PHOTO_ANALYSIS=true
FEATURE_AGENTMD_REVIEW=false
FEATURE_ANALYTICS=true
FEATURE_ADVANCED_EXPORTS=true
FEATURE_REALTIME_NOTIFICATIONS=true
FEATURE_OFFLINE_MODE=true
FEATURE_CUSTOM_FORMS=true
FEATURE_VOICE_INPUT=false
FEATURE_RED_TEAM=false
