# =============================================================================
# FLEET ACCIDENT REPORTER - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values.
# Used for onboarding new users and development server setup.
# =============================================================================

# -----------------------------------------------------------------------------
# CORE
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# -----------------------------------------------------------------------------
# DATABASE (Choose one provider - Supabase is default)
# -----------------------------------------------------------------------------
# DB_PROVIDER: supabase | neon | postgres | snowflake | sql_server
# When using Supabase/Neon, DATABASE_URL takes precedence over DB_* vars.
DB_PROVIDER=supabase

# --- Option 1: Supabase (DEFAULT - recommended for onboarding)
# Get from: Supabase Dashboard → Project Settings → Database
# Use "Connection string" → "URI" (Transaction pooler for serverless)
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase project URL & keys (for client-side auth, Realtime, Storage)
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Option 2: Neon (serverless Postgres)
# DATABASE_URL=postgresql://[user]:[password]@[endpoint].neon.tech/[dbname]?sslmode=require

# --- Option 3: Generic PostgreSQL (self-hosted or managed)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=accident_app
# DB_USER=postgres
# DB_PASSWORD=your_password

# --- Option 4: Snowflake (data warehouse - requires adapter)
# SNOWFLAKE_ACCOUNT=your_account
# SNOWFLAKE_USER=your_user
# SNOWFLAKE_PASSWORD=your_password
# SNOWFLAKE_WAREHOUSE=your_warehouse
# SNOWFLAKE_DATABASE=accident_app

# --- Option 5: Azure SQL / SQL Server
# DB_PROVIDER=sql_server
# DB_HOST=your-server.database.windows.net
# DB_PORT=1433
# DB_NAME=accident_app
# DB_USER=your_user
# DB_PASSWORD=your_password

# Pool settings (when using DB_* vars)
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=10000
DB_CONNECTION_TIMEOUT=2000
DB_SSL=true

# -----------------------------------------------------------------------------
# AUTHENTICATION (Auth0 for cloud provider sign-in)
# -----------------------------------------------------------------------------
# Auth0: https://auth0.com/docs/get-started
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret
AUTH0_CALLBACK_URL=http://localhost:3000/api/auth/callback
AUTH0_AUDIENCE=

# JWT (fallback when not using Auth0)
JWT_SECRET=your_jwt_secret_min_32_characters_required
JWT_EXPIRES_IN=24h

# -----------------------------------------------------------------------------
# CLOUD STORAGE (Choose one: AWS | Azure | GCP)
# -----------------------------------------------------------------------------
# CLOUD_PROVIDER: aws | azure | gcp
CLOUD_PROVIDER=aws

# --- AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=your_bucket_name

# --- Azure Blob Storage
# AZURE_STORAGE_ACCOUNT=your_storage_account
# AZURE_STORAGE_ACCESS_KEY=your_access_key
# AZURE_STORAGE_CONTAINER=accident-app-uploads

# --- Google Cloud Storage
# GCP_PROJECT_ID=your_project_id
# GCP_CLIENT_EMAIL=your_service_account@project.iam.gserviceaccount.com
# GCP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# GCP_STORAGE_BUCKET=your_bucket_name

# -----------------------------------------------------------------------------
# AI PROVIDERS (Choose one or more - set API keys for providers you use)
# -----------------------------------------------------------------------------
# AI_PROVIDER: openai | anthropic | ollama | mistral | openrouter | aws_rekognition | google_vision | azure_vision
AI_PROVIDER=openai
AI_MIN_CONFIDENCE=70

# OpenAI
OPENAI_API_KEY=sk-your_openai_api_key

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Ollama (local - no key needed, set base URL)
OLLAMA_BASE_URL=http://localhost:11434

# Mistral AI
MISTRAL_API_KEY=your_mistral_api_key

# OpenRouter (unified API for multiple models)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# AWS Rekognition (image analysis - uses AWS credentials above)
# AI_PROVIDER=aws_rekognition

# Google Vision (requires GCP credentials)
# AI_PROVIDER=google_vision

# Azure Computer Vision
# AZURE_VISION_KEY=your_azure_vision_key
# AZURE_VISION_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

# -----------------------------------------------------------------------------
# TELEMATICS & KILL SWITCH
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=your_encryption_key_min_32_characters_required
KILL_SWITCH_AUTO_ENGAGE=true
KILL_SWITCH_TIMEOUT_HOURS=24

# -----------------------------------------------------------------------------
# CORS & SESSION
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:3001,http://localhost:19006,http://localhost:5173
SESSION_SECRET=your_session_secret_min_32_characters_required
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_FILE_PATH=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14d

# -----------------------------------------------------------------------------
# EMAIL (Optional)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@localhost

# -----------------------------------------------------------------------------
# MONITORING (Optional)
# -----------------------------------------------------------------------------
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
ENABLE_SWAGGER_DOCS=true
ENABLE_DEBUG_LOGGING=true
ENABLE_METRICS=true

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900000

# -----------------------------------------------------------------------------
# FILE UPLOAD
# -----------------------------------------------------------------------------
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# -----------------------------------------------------------------------------
# WEBSOCKET
# -----------------------------------------------------------------------------
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000
