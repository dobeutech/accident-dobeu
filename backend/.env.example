# =============================================================================
# FLEET ACCIDENT REPORTER — BACKEND ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in real values before starting the server.
# NEVER commit .env (real credentials) to version control.
#
# ONBOARDING CHECKLIST FOR NEW DEVELOPERS:
#  1. Choose a DATABASE provider  (Section: DATABASE)
#  2. Choose a CLOUD STORAGE provider  (Section: CLOUD STORAGE)
#  3. Choose an AI provider  (Section: AI PROVIDERS)
#  4. Set up Auth0  (Section: AUTHENTICATION)
#  5. Generate secure secrets  (Section: SECRETS HELPER below)
#  6. Configure CORS origins to match your frontend URLs
#
# GENERATE SECURE RANDOM SECRETS (run in terminal):
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# =============================================================================


# -----------------------------------------------------------------------------
# CORE SERVER
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
# Set to 1 when running behind nginx / a load balancer / Heroku / Railway / Render
TRUST_PROXY=false


# -----------------------------------------------------------------------------
# DATABASE
# Choose ONE provider. Uncomment that block and leave others commented out.
# Default: Supabase (recommended for new projects)
#
# Supported: supabase | neon | postgresql | snowflake
# -----------------------------------------------------------------------------
DB_PROVIDER=supabase

# Connection pool settings (apply to all providers)
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=10000
DB_CONNECTION_TIMEOUT=30000
DB_SSL=true


## ── OPTION 1: Supabase (DEFAULT) ─────────────────────────────────────────────
## Dashboard → Project Settings → Database → Connection Pooling
## Use the "Transaction Pooler" string (port 6543) for pooled connections.
## Use the "Direct Connection" string (port 5432) for migrations / Prisma.
##
## Project ref: the alphanumeric string in your Supabase project URL.

DATABASE_URL=postgresql://postgres.[project-ref]:[db-password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL_DIRECT=postgresql://postgres:[db-password]@db.[project-ref].supabase.co:5432/postgres

# Supabase JS client credentials (for Realtime, Auth helper, Storage SDK)
# Dashboard → Project Settings → API
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_service_role_key_here

# Individual host/port params (required by Sequelize; derived from DATABASE_URL above)
DB_HOST=aws-0-[region].pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.[project-ref]
DB_PASSWORD=your_supabase_db_password


## ── OPTION 2: Neon (Serverless Postgres) ─────────────────────────────────────
## https://console.neon.tech → Project → Connection Details
#
# DB_PROVIDER=neon
# DATABASE_URL=postgresql://[user]:[password]@[endpoint-id].neon.tech/[dbname]?sslmode=require
# DATABASE_URL_DIRECT=postgresql://[user]:[password]@[endpoint-id].neon.tech/[dbname]?sslmode=require
# NEON_PROJECT_ID=your_neon_project_id
#
# DB_HOST=[endpoint-id].neon.tech
# DB_PORT=5432
# DB_NAME=neondb
# DB_USER=your_neon_user
# DB_PASSWORD=your_neon_password


## ── OPTION 3: Local / Direct PostgreSQL ──────────────────────────────────────
#
# DB_PROVIDER=postgresql
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/accident_app
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=accident_app
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_SSL=false


## ── OPTION 4: Snowflake ──────────────────────────────────────────────────────
## https://app.snowflake.com → Admin → Accounts
#
# DB_PROVIDER=snowflake
# SNOWFLAKE_ACCOUNT=orgname-account_name
# SNOWFLAKE_USER=your_snowflake_user
# SNOWFLAKE_PASSWORD=your_snowflake_password
# SNOWFLAKE_DATABASE=ACCIDENT_APP
# SNOWFLAKE_SCHEMA=PUBLIC
# SNOWFLAKE_WAREHOUSE=COMPUTE_WH
# SNOWFLAKE_ROLE=ACCOUNTADMIN
# DATABASE_URL=snowflake://[user]:[password]@[account]/[database]/[schema]


# -----------------------------------------------------------------------------
# AUTHENTICATION — Auth0 (OAuth 2.0 / OIDC)
# https://manage.auth0.com → Applications → Create Application
# Application type: Regular Web Application (backend) + SPA (frontend)
# -----------------------------------------------------------------------------
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
AUTH0_AUDIENCE=https://api.your-app.com
AUTH0_CALLBACK_URL=http://localhost:3000/auth/callback
AUTH0_LOGOUT_URL=http://localhost:3001
# Management API (for user management features)
AUTH0_MANAGEMENT_CLIENT_ID=your_management_client_id
AUTH0_MANAGEMENT_CLIENT_SECRET=your_management_client_secret


# JWT (tokens issued locally or validated from Auth0)
JWT_SECRET=REPLACE_ME_with_64+_random_hex_chars_from_crypto_randomBytes
JWT_EXPIRES_IN=24h

# Session
SESSION_SECRET=REPLACE_ME_with_64+_random_hex_chars_different_from_JWT_SECRET
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Brute-force protection
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900000

# IP Whitelist (comma-separated CIDRs, empty = allow all)
IP_WHITELIST=


# -----------------------------------------------------------------------------
# CLOUD STORAGE
# Choose ONE provider. Uncomment that block and leave others commented out.
# Default: AWS S3
#
# Supported: aws | azure | gcp
# -----------------------------------------------------------------------------
CLOUD_PROVIDER=aws


## ── OPTION 1: AWS S3 (DEFAULT) ───────────────────────────────────────────────
## https://console.aws.amazon.com → IAM → Users → Security credentials
## Minimum IAM permissions: s3:GetObject, s3:PutObject, s3:DeleteObject, s3:HeadBucket
## AI/Rekognition also uses these credentials when AI_PROVIDER=aws_rekognition

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_S3_BUCKET=your-accident-app-bucket
# Optional: S3-compatible endpoint (MinIO, DigitalOcean Spaces, Cloudflare R2, etc.)
# AWS_ENDPOINT_URL=https://your-custom-endpoint.com
# Optional: assume an IAM role instead of static keys (EC2 / ECS / Lambda)
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/AccidentAppRole
# Optional: CloudFront CDN in front of S3
# AWS_CLOUDFRONT_DOMAIN=d1234567890.cloudfront.net


## ── OPTION 2: Azure Blob Storage ─────────────────────────────────────────────
## https://portal.azure.com → Storage Accounts → Access Keys
#
# CLOUD_PROVIDER=azure
# AZURE_STORAGE_ACCOUNT_NAME=youraccountname
# AZURE_STORAGE_ACCOUNT_KEY=your_storage_account_key_base64
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
# AZURE_STORAGE_CONTAINER_NAME=accident-photos
# AZURE_STORAGE_SAS_TOKEN=sv=2023-01-03&...
# Optional: Azure CDN
# AZURE_CDN_ENDPOINT=https://your-cdn-endpoint.azureedge.net


## ── OPTION 3: Google Cloud Storage (GCP) ────────────────────────────────────
## https://console.cloud.google.com → IAM → Service Accounts → JSON key
#
# CLOUD_PROVIDER=gcp
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_STORAGE_BUCKET=your-accident-app-bucket
# GCP_SERVICE_ACCOUNT_KEY_PATH=./config/gcp-service-account.json
# GCP_SERVICE_ACCOUNT_EMAIL=accident-app@your-project.iam.gserviceaccount.com
# Optional: GCP CDN / Cloud Armor
# GCP_CDN_DOMAIN=https://storage.googleapis.com


# -----------------------------------------------------------------------------
# AI PROVIDERS
# Choose ONE primary provider for image analysis and AI features.
# Default: OpenAI GPT-4o
#
# Supported: openai | anthropic | aws_rekognition | ollama | mistral | openrouter
# -----------------------------------------------------------------------------
AI_PROVIDER=openai
AI_MIN_CONFIDENCE=70


## ── OPTION 1: OpenAI (DEFAULT) ───────────────────────────────────────────────
## https://platform.openai.com/api-keys

OPENAI_API_KEY=sk-proj-your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.2
# Optional: organization ID
# OPENAI_ORGANIZATION=org-xxxxxxxxxxxxxxxx


## ── OPTION 2: Anthropic / Claude ─────────────────────────────────────────────
## https://console.anthropic.com/keys
#
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-api03-your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-opus-4-5
# ANTHROPIC_VISION_MODEL=claude-opus-4-5
# ANTHROPIC_MAX_TOKENS=4096


## ── OPTION 3: AWS Rekognition (original implementation) ─────────────────────
## Re-uses AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY from Cloud Storage section.
## No extra keys required; just switch the provider flag.
#
# AI_PROVIDER=aws_rekognition
# AWS_REKOGNITION_REGION=us-east-1


## ── OPTION 4: Ollama (Self-Hosted / Local / Offline) ────────────────────────
## Install: https://ollama.ai  |  Docker: docker run -d -p 11434:11434 ollama/ollama
## Pull model first: ollama pull llava
#
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
# OLLAMA_VISION_MODEL=llava


## ── OPTION 5: Mistral AI ─────────────────────────────────────────────────────
## https://console.mistral.ai/api-keys
#
# AI_PROVIDER=mistral
# MISTRAL_API_KEY=your_mistral_api_key_here
# MISTRAL_MODEL=mistral-large-latest
# MISTRAL_VISION_MODEL=pixtral-large-latest


## ── OPTION 6: OpenRouter (Multi-Provider Gateway) ────────────────────────────
## https://openrouter.ai/keys — access 100+ models with one API key
#
# AI_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=openai/gpt-4o
# OPENROUTER_VISION_MODEL=openai/gpt-4o
# OPENROUTER_SITE_URL=http://localhost:3000
# OPENROUTER_SITE_NAME=Fleet Accident Reporter


# -----------------------------------------------------------------------------
# EMAIL / NOTIFICATIONS
# Choose ONE provider. Uncomment that block and leave others commented out.
# Default: SMTP
#
# Supported: smtp | sendgrid | ses | resend | azure_email
# -----------------------------------------------------------------------------
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@your-app.com


## ── OPTION 1: SMTP / Gmail (DEFAULT) ─────────────────────────────────────────
## Gmail: use an App Password (not your main password)
## https://myaccount.google.com/apppasswords

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here


## ── OPTION 2: SendGrid ───────────────────────────────────────────────────────
## https://app.sendgrid.com/settings/api_keys
#
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.your_sendgrid_api_key_here


## ── OPTION 3: AWS SES ────────────────────────────────────────────────────────
## Re-uses AWS credentials from Cloud Storage section.
## Verify your sender domain in SES first.
#
# EMAIL_PROVIDER=ses
# SES_REGION=us-east-1


## ── OPTION 4: Resend ─────────────────────────────────────────────────────────
## https://resend.com/api-keys
#
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_your_resend_api_key_here


## ── OPTION 5: Azure Communication Services Email ─────────────────────────────
## https://portal.azure.com → Communication Services → Email → Domains
#
# EMAIL_PROVIDER=azure_email
# AZURE_COMMUNICATION_CONNECTION_STRING=endpoint=https://...;accesskey=base64==
# AZURE_EMAIL_SENDER=DoNotReply@your-azure-domain.azurecomm.net


# -----------------------------------------------------------------------------
# CORS & API GATEWAY
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins (no trailing slash)
CORS_ORIGIN=http://localhost:3001,http://localhost:19006,http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100


# -----------------------------------------------------------------------------
# LOGGING & MONITORING
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14d
LOG_QUERIES=false
SLOW_QUERY_THRESHOLD=1000

# Sentry — https://sentry.io/settings/[org]/projects/[project]/keys/
SENTRY_DSN=

# New Relic — https://one.newrelic.com/admin-portal/api-keys/home
NEW_RELIC_LICENSE_KEY=

# Datadog
# DD_API_KEY=your_datadog_api_key
# DD_SITE=datadoghq.com


# -----------------------------------------------------------------------------
# FILE UPLOAD
# -----------------------------------------------------------------------------
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf


# -----------------------------------------------------------------------------
# WEBSOCKET
# -----------------------------------------------------------------------------
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000


# -----------------------------------------------------------------------------
# TELEMATICS & KILL SWITCH
# -----------------------------------------------------------------------------
# 32+ character encryption key for stored telematics API credentials
ENCRYPTION_KEY=REPLACE_ME_with_64+_random_hex_chars_different_from_JWT_or_SESSION

KILL_SWITCH_AUTO_ENGAGE=true
KILL_SWITCH_TIMEOUT_HOURS=24

# Telematics provider API keys (stored encrypted in DB; dev defaults below)
# These are only needed in dev if you want to test telematics integration directly.
# GEOTAB_DATABASE=your_geotab_database
# GEOTAB_USERNAME=your_geotab_username
# GEOTAB_PASSWORD=your_geotab_password
# SAMSARA_API_KEY=token_your_samsara_api_key
# VERIZON_CONNECT_USERNAME=your_vc_username
# VERIZON_CONNECT_PASSWORD=your_vc_password
# FLEET_COMPLETE_API_KEY=your_fleet_complete_api_key
# TELETRAC_NAVMAN_API_KEY=your_teletrac_api_key


# -----------------------------------------------------------------------------
# FEATURE FLAGS
# Defaults shown are for a full-featured development environment.
# Set to false/true to toggle individual features.
# -----------------------------------------------------------------------------
ENABLE_SWAGGER_DOCS=true
ENABLE_DEBUG_LOGGING=false
ENABLE_METRICS=true

FEATURE_AGENTMD_REVIEW=true
FEATURE_RED_TEAM=false
FEATURE_ANALYTICS=true
FEATURE_ADVANCED_EXPORTS=true
FEATURE_REALTIME_NOTIFICATIONS=true
FEATURE_OFFLINE_MODE=true
FEATURE_CUSTOM_FORMS=true
FEATURE_AI_ASSISTANT=true
FEATURE_VOICE_INPUT=false
FEATURE_PHOTO_ANALYSIS=true
