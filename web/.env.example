# API Configuration (use /api when proxying, or full URL)
VITE_API_URL=http://localhost:3000/api

# Environment
VITE_ENV=development

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_TRACKING=true

# Analytics (Optional)
VITE_GA_TRACKING_ID=
VITE_MIXPANEL_TOKEN=

# Error Tracking (Optional)
VITE_SENTRY_DSN=

# App Configuration
VITE_APP_NAME=Fleet Accident Reporter
VITE_APP_VERSION=1.0.0
