modules = ["nodejs-20", "bash", "web"]
[nix]
channel = "stable-25_05"
packages = ["unzip"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Fleet Accident App"

[[workflows.workflow]]
name = "Fleet Accident App"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "(cd backend && node src/server.js &) && cd web && npx vite --host 0.0.0.0 --port 5000"
waitForPort = 5000

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 3001
externalPort = 3003

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3002

[userenv]

[userenv.shared]
NODE_ENV = "development"
PORT = "3000"
JWT_SECRET = "9931e25ebfd847960ff4a5949f23ea6c99105e5cf612a7d6d2387233f91d6d3898ae676d19b81907986c511527fa5c3a"

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "cd backend && node src/server.js"]
build = ["bash", "-c", "cd web && npm install && npm run build"]
